{
  "name": "@sparfuchs/data-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "run:once": "tsx src/run.ts",
    "start:cron": "tsx src/scheduler.ts",
    "fetch:rewe": "tsx src/sources/rewe.ts",
    "fetch:lidl": "tsx src/sources/lidl.ts",
    "repair:images": "tsx src/repair-images.ts"
  },
  "dependencies": {
    "@sparfuchs/api": "workspace:*",
    "@sparfuchs/shared": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/browser-chromium": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
