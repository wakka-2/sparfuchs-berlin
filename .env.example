# ============================================
# Sparfuchs Berlin — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
# Production deployment:
#   API  → Railway   (set vars in Railway dashboard)
#   Web  → Vercel    (set VITE_* vars in Vercel project settings)

# ============================================
# DATABASE (Railway Postgres or self-hosted)
# ============================================
# Railway auto-provides DATABASE_URL when you link a Postgres service.
# DATABASE_URL_DIRECT is used by Drizzle Kit (bypasses PgBouncer pooling).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sparfuchs
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/sparfuchs

# ============================================
# REDIS (Railway Redis or self-hosted)
# ============================================
# Railway auto-provides REDIS_URL when you link a Redis service.
# Optional — the API degrades gracefully when Redis is unavailable.
REDIS_URL=redis://localhost:6379

# ============================================
# DATA PIPELINE — REWE (Pepesto API)
# ============================================
# Sign up at https://pepesto.com to get a key.
PEPESTO_API_KEY=your_pepesto_api_key_here
PEPESTO_BASE_URL=https://api.pepesto.com

# ============================================
# DATA PIPELINE — Lidl (Apify)
# ============================================
# Sign up at https://apify.com and get a token from
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here
APIFY_LIDL_ACTOR_ID=easyapi/lidl-product-scraper

# ============================================
# APPLICATION SERVER
# ============================================
NODE_ENV=development
PORT=3001

# Comma-separated list of allowed CORS origins.
# Production example: CORS_ORIGINS=https://sparfuchs-berlin.de
CORS_ORIGINS=http://localhost:5173

# ============================================
# FRONTEND (Vite build-time env vars)
# ============================================
# Set this in Vercel project settings under Environment Variables.
# Production: VITE_API_URL=https://api.sparfuchs-berlin.de/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# ============================================
# PIPELINE SCHEDULE (cron syntax, Europe/Berlin TZ)
# ============================================
PIPELINE_CRON_REWE=0 5 * * *
PIPELINE_CRON_LIDL=30 5 * * *

# ============================================
# RATE LIMITING
# ============================================
# Maximum requests per IP per minute (default: 100)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# ============================================
# MONITORING (optional)
# ============================================
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# LOG_LEVEL=info

# ============================================
# GITHUB ACTIONS — DEPLOYMENT SECRETS
# ============================================
# Set these in GitHub → Settings → Secrets → Actions (not in .env):
#   RAILWAY_TOKEN         Railway API token
#   RAILWAY_SERVICE_ID    Service ID from Railway dashboard
#   VERCEL_TOKEN          Vercel API token
#   VERCEL_ORG_ID         Vercel organization/team ID
#   VERCEL_PROJECT_ID     Vercel project ID
