{
  "name": "@sparfuchs/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./db/schema": {
      "types": "./src/db/schema.ts",
      "import": "./dist/db/schema.js"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "import": "./dist/db/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "start:prod": "node dist/start-production.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:dev": "tsx src/db/dev-db.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@sparfuchs/shared": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.0",
    "ioredis": "^5.6.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "embedded-postgres": "18.3.0-beta.16",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
